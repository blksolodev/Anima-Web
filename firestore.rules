rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      // Allow owner to update anything, or others to update only stats (for follow counts)
      allow update: if isAuthenticated() && (
        isOwner(userId) || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats'])
      );
      allow delete: if isOwner(userId);

      // Followers subcollection - public read, managed by follow/unfollow actions
      match /followers/{followerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
      }

      // Following subcollection - public read, managed by follow/unfollow actions
      match /following/{followingId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Likes subcollection - user's liked posts
      match /likes/{likeId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Reposts subcollection - user's reposted posts
      match /reposts/{repostId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
      
      // Settings subcollection - user's preferences
      match /settings/{settingsId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      // Blocked users subcollection - user's block list
      match /blocked/{blockedId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Spoiler verifications - tracks which episodes a user has verified watching
      match /spoiler_verifications/{discussionId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Discussion Rooms
    match /discussions/{discussionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messageCount', 'postCount'])
      );
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      }
    }

    // Quests (posts) collection - authenticated users can read all, write their own
    match /quests/{questId} {
      allow read: if true; // Public read for feed
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      // Allow author to update/delete, or any authenticated user to update likes/reposts
      allow update: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likesCount', 'reposts', 'repostsCount', 'replies', 'repliesCount']))
      );
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      
      // Distributed Counter Shards (NEW) - Authenticated users can increment shards
      match /shards/{shardId} {
        allow read: if isAuthenticated();
        // Allow any authenticated user to write to a shard (for incrementing likes)
        // Ideally, use cloud functions for strict validation, but for client-side counters:
        allow write: if isAuthenticated();
      }

      // Replies subcollection - users can read all, write their own
      match /replies/{replyId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      }
    }

    // Anime Library - users can read any, write their own
    match /anime_library/{entryId} {
      // Allow authenticated users to read any library entry (for profile views)
      allow read, list: if isAuthenticated();

      // Doc ID is {userId}_{animeId} — ownership verified by ID prefix
      allow create: if isAuthenticated() && entryId.matches(request.auth.uid + '_.*');
      allow update, delete: if isAuthenticated() && entryId.matches(request.auth.uid + '_.*');
    }
    
    // Notifications - users can only access their own
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow list: if isAuthenticated();
    }
    
    // Allow collection group queries across all replies subcollections
    match /{path=**}/replies/{replyId} {
      allow read: if isAuthenticated();
    }

    // Guild Chats - authenticated users can participate
    match /guild_chats/{roomId} {
      allow read, write: if isAuthenticated();
      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // Direct Message Conversations - only participants can read/write
    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
      }
    }

    // Arena Takes - public read, authenticated write
    match /arena_takes/{takeId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }
    
    // Cutscenes - public read, authenticated write
    match /cutscenes/{cutsceneId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }
    
    // Reports - users can create, only admins/functions can read
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    // Stamps and Badges - read only (managed by admin/functions)
    match /stamps/{stampId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin only
    }
    match /badges/{badgeId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin only
    }
  }
}
